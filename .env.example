# Supabase local (Postgres)
DATABASE_DSN=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Proceso por defecto (EG 2026)
JNE_PROCESS_ID=124

# Tipo de eleccion por defecto (si no pasas --tipo-eleccion-id)
JNE_TIPO_ELECCION_NOMBRE=PRESIDENCIAL
# Opcional: usar ID directo en vez de nombre
# JNE_TIPO_ELECCION_ID=1

# Tamano de pagina para busqueda avanzada
JNE_PAGE_SIZE=20

# Opcional: limite de paginas para pruebas
# JNE_MAX_PAGES=2

# Opcional: particionar ingesta por id_hoja_vida (para corridas paralelas)
# Deben enviarse juntos (ej. 4 procesos con rem 0..3)
# JNE_PARTITION_MOD=4
# JNE_PARTITION_REM=0

# Timeout/reintentos HTTP
JNE_TIMEOUT_SECONDS=45
JNE_REQUEST_RETRIES=3
JNE_BACKOFF_SECONDS=1.0
JNE_CAPTCHA_RETRIES=4
JNE_LOG_LEVEL=INFO

# En JNE suele requerirse desactivar verificacion SSL por cadena incompleta
JNE_VERIFY_SSL=false

# Modo de busqueda avanzada:
# - api: POST directo con httpx
# - browser: ejecucion desde Playwright dentro del navegador (mejor para anti-bot)
JNE_SEARCH_MODE=api

# Playwright token provider (recomendado local)
# false: navegador visible (mejor tasa de aceptacion recaptcha)
JNE_PLAYWRIGHT_HEADLESS=false
JNE_PLAYWRIGHT_TIMEOUT_MS=60000
# Canal opcional: chrome | msedge | chromium
# JNE_PLAYWRIGHT_CHANNEL=chrome
# Perfil persistente opcional para modo browser (cookies/sesion)
# JNE_PLAYWRIGHT_USER_DATA_DIR=/tmp/jne-browser-profile

# Token de recaptcha enterprise (si se usa modo token fijo)
# JNE_RECAPTCHA_TOKEN=

# Copilot IA (OpenAI)
# Si no se configura OPENAI_API_KEY, /api/v1/copilot/ask-ai cae a modo fallback SQL.
# OPENAI_API_KEY=<SECRET>
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
COPILOT_SESSION_HISTORY_LIMIT=3
COPILOT_SESSION_MAX_TURNS=20
COPILOT_SESSION_MAX_SESSIONS=500
# Clave opcional para firmar session_id del copilot (si no se define, usa una efimera por proceso)
# COPILOT_SESSION_SIGNING_KEY=

# Cache en memoria para dashboard (`GET /api/v1/dashboard/insights`), en segundos.
# Usa 0 para desactivar cache.
DASHBOARD_CACHE_TTL_SECONDS=60

# Beta publica (API)
# CORS: lista separada por comas (ej. https://beta.midominio.com,https://admin.midominio.com)
# API_CORS_ALLOW_ORIGINS=
# API keys validas separadas por coma. Si esta vacio, no se exige API key.
# BETA_API_KEYS=
# Subconjunto opcional de keys con permiso para /api/v1/copilot/ask-ai.
# Si se omite, cualquier key valida puede usar ask-ai.
# BETA_AI_API_KEYS=
# Exigir key en endpoints de lectura /api/v1/*.
BETA_ENFORCE_API_KEY_READ=false
# Exigir key en endpoint /api/v1/copilot/ask-ai.
BETA_ENFORCE_API_KEY_AI=true
# Permitir /health sin API key aun cuando existan keys configuradas.
BETA_ALLOW_ANON_HEALTH=true
# Rate limits por ventana.
# Usa 0 para desactivar un limite especifico.
BETA_RATE_LIMIT_READ_PER_MINUTE=120
BETA_RATE_LIMIT_COPILOT_PER_MINUTE=40
BETA_RATE_LIMIT_AI_PER_MINUTE=20
BETA_RATE_LIMIT_WINDOW_SECONDS=60
# Usar X-Forwarded-For para identificar IP cliente (recomendado detras de proxy/WAF).
BETA_TRUST_PROXY_HEADERS=true

# Guardrails de SQL readonly del planner IA.
READONLY_SQL_TIMEOUT_MS=2500
READONLY_SQL_MAX_ROWS=50

# Instagram discovery (fase inicial)
# Token Graph API para Business Discovery
# INSTAGRAM_GRAPH_ACCESS_TOKEN=
# IG User ID profesional (app user) para consultas business_discovery
# INSTAGRAM_APP_USER_IG_ID=
